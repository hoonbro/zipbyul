# 집별 환경변수 예시 — 복사해서 .env 로 채운다. .env 는 커밋 금지.

# ── 공유 PostgreSQL (SSOT) ──────────────────────
POSTGRES_DB=jipbyul
POSTGRES_USER=jipbyul
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis (Spring 캐시·간단 큐) ─────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── 공공데이터 API 키 (0주차 PoC에서 발급) ────────
# data.go.kr 활용신청 — 영리 가능 여부 확인
DATA_GO_KR_SERVICE_KEY=
# 청약홈(한국부동산원) / LH / 국토부 실거래가는 위 서비스키 또는 개별 발급
APPLYHOME_API_KEY=
LH_API_KEY=
MOLIT_RTMS_API_KEY=

# 한국은행 ECOS (서울 주택가격전망 CSI · 기준금리). 출처표시 의무.
ECOS_API_KEY=

# ── 알림 (FCM / Web Push) ───────────────────────
FCM_PROJECT_ID=
FCM_CREDENTIALS_JSON=/run/secrets/firebase-service-account.json
NOTIFICATION_CONSUMER_ENABLED=true
WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_PRIVATE_KEY=

# ── (선택) AI 공고 요약 LLM ─────────────────────
ANTHROPIC_API_KEY=

# ── 시간대 (전 계층 고정) ───────────────────────
TZ=Asia/Seoul
