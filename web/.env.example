# 집별 web (Vite) 환경변수 예시 — 복사해서 .env.local 로 채운다.
# VITE_ 접두사만 클라이언트에 노출된다. (Firebase 웹 config·VAPID 공개키는 공개값이라 안전)

# 백엔드 API
VITE_API_BASE_URL=http://localhost:8080

# Web Push (백엔드 .env의 WEBPUSH_VAPID_PUBLIC_KEY와 동일 값)
VITE_VAPID_PUBLIC_KEY=

# Firebase 웹 앱 config (Firebase 콘솔 > 프로젝트 설정 > 웹 앱)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=zipbyul
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
